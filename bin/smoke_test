#!/usr/bin/env bash
#
# Release acceptance suite (~2 min, network). Builds a throwaway skeleton app
# from the committed HEAD of the current branch and exercises the gem end to
# end. See acceptance/acceptance_helper.rb.

set -euo pipefail
cd "$(dirname "$0")/.."

exec bundle exec rspec --options acceptance/.rspec --pattern 'acceptance/*_spec.rb'
