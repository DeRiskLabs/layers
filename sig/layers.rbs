module Layers
  VERSION: String

  class Error < StandardError
  end

  class ConfigurationError < Error
  end

  class ContractViolation < Error
  end

  def self.configuration: () -> Configuration

  def self.configure: () { (Configuration) -> void } -> void

  class Configuration
    attr_accessor logger: untyped
    attr_accessor reveal_masked_errors: bool?

    def exposed_error_classes: () -> Array[Class]
    def exposed_error_classes=: (Array[Class]) -> Array[Class]
    def graphql_execution_error: () -> untyped
    def graphql_execution_error=: (untyped) -> untyped
    def masked_error_message: () -> String
    def masked_error_message=: (String) -> String
    def pagination_adapter: () -> untyped
    def pagination_adapter=: (untyped) -> untyped
    def relation_adapter: () -> untyped
    def relation_adapter=: (untyped) -> untyped

    private

    def detect_graphql_execution_error: () -> untyped
    def detect_pagination_adapter: () -> untyped
  end

  class Logger < ::Logger
    include Singleton

    def self.logger: () -> untyped
  end

  class Instrumenter
    attr_reader subject: untyped
    attr_reader listener: untyped
    attr_reader on_failure: Symbol
    attr_reader on_success: Symbol
    attr_reader outcome_args: Array[untyped]?
    attr_reader outcome_opts: Hash[Symbol, untyped]?
    attr_reader started_at: Float

    def initialize: (subject: untyped, listener: untyped, on_failure: Symbol, on_success: Symbol) -> void

    def success: (*untyped success_args, **untyped success_opts) -> untyped
    def failure: (*untyped failure_args, **untyped failure_opts) -> untyped

    private

    def capture: (Array[untyped] args, Hash[Symbol, untyped] opts) -> void
    def elapsed_ms: () -> Float
    def instrument!: (Symbol outcome) -> void
    def logger: () -> untyped
  end

  module DSL
    class MissingRequiredInputs < ArgumentError
    end

    class UnexpectedInputs < ArgumentError
    end

    class MissingDeclaredOutputs < Layers::Error
    end

    class UndeclaredOutputs < Layers::Error
    end

    class NotImplementedError < ::NotImplementedError
    end

    module Emits
      def self.included: (Module base) -> void

      module ClassMethods
        def emits: (?success: Array[Symbol]?, ?failure: Array[Symbol]?) -> void
        def emitted_success_keys: () -> Set[Symbol]?
        def emitted_failure_keys: () -> Set[Symbol]?
      end

      private

      def validate_emitted!: (Symbol outcome, Hash[Symbol, untyped] opts) -> void
      def verify_listener_contract!: () -> void
      def verify_callback!: (Symbol outcome, Symbol callback_name) -> void
      def verify_required_keywords!: (Symbol outcome, Symbol callback_name, Set[Symbol] declared, Array[untyped] parameters) -> void
      def verify_receivable_keys!: (Symbol outcome, Symbol callback_name, Set[Symbol] declared, Array[untyped] parameters) -> void
      def callback_parameters: (Symbol callback_name) -> Array[untyped]?
      def keyword_aware?: (Array[untyped] parameters) -> bool
      def required_keywords: (Array[untyped] parameters) -> Array[Symbol]
      def accepted_keywords: (Array[untyped] parameters) -> Array[Symbol]
      def keyrest?: (Array[untyped] parameters) -> bool
      def declared_keys_for: (Symbol outcome) -> Set[Symbol]?
    end

    module CallbackDefaults
      ON_FAILURE_DEFAULT_CALLBACK: Symbol
      ON_SUCCESS_DEFAULT_CALLBACK: Symbol

      def self.included: (Module base) -> void

      module ClassMethods
        def default_callbacks: (?on_failure: Symbol?, ?on_success: Symbol?) -> void
        def on_failure_default: () -> Symbol
        def on_success_default: () -> Symbol
      end

      module InstanceMethods
        attr_reader on_failure_default: Symbol
        attr_reader on_success_default: Symbol

        def initialize: (*untyped args, **untyped opts) -> void
      end
    end

    module ClassCallable
      class MissingMethodError < StandardError
        def initialize: (Exception original_error, String? klass_name) -> void
      end

      def self.included: (Module base) -> void

      module ClassMethods
        def call: (*untyped args, **untyped opts) -> untyped
      end

      def call: () -> untyped
    end

    module Inputs
      def self.included: (Module base) -> void

      module ClassMethods
        def all_inputs: () -> Set[Symbol]
        def optional: (*Symbol input_names) -> void
        def optional_inputs: () -> Set[Symbol]
        def required: (*Symbol input_names) -> void
        def required_inputs: () -> Set[Symbol]
        def optional_with_default: (**untyped defaults_hash) -> void
        def default_inputs: () -> Hash[Symbol, untyped]
      end

      attr_accessor inputs: Hash[Symbol, untyped]

      def initialize: (?Hash[Symbol, untyped] inputs) -> void

      def attributes: () -> Hash[Symbol, untyped]
      def optional_attributes: () -> Hash[Symbol, untyped]
      def required_attributes: () -> Hash[Symbol, untyped]

      private

      def add_default_inputs!: () -> void
      def default_inputs: () -> Hash[Symbol, untyped]
      def extra_inputs: () -> Array[Symbol]
      def missing_inputs: () -> Array[Symbol]
      def received_inputs: () -> Array[Symbol]
      def set_attributes_from_inputs!: () -> void
      def validate_required_inputs_present!: () -> void
      def validate_no_unpermitted_inputs!: () -> void
    end

    module Instrumented
      def self.included: (Module base) -> void

      module ClassMethods
        def instrument: (*Class instrumenter_classes) -> void
        def instrumenters: () -> Set[Class]
      end

      private

      def insert_instrumenters!: () -> void
    end

    module NullListener
      private

      def null_listener: () -> untyped
      def null_listener_factory: () -> untyped
    end

    module Observers
      def self.included: (Module base) -> void

      module ClassMethods
        attr_reader observer_exception_handler_method: Symbol?

        def observer: (*untyped observer_methods, ?of_event: Symbol) -> void
        def observers: () -> Hash[Symbol, Set[untyped]]
        def observer_exception_handler: (Symbol exception_handler_method_name) -> Symbol
      end

      def notify_observers: (?of_event: Symbol) -> void
      def observers: () -> Hash[Symbol, Set[untyped]]

      private

      def exception_handler_method: () -> Symbol?
      def handle_observer_exception: (Exception exception) -> void
      def logger: () -> untyped
      def observers_array: (?of_event: Symbol) -> Array[untyped]
      def safely_invoke_observer: (untyped observer) -> untyped
    end
  end

  class BaseLayer
    include DSL::Observers
    extend DSL::Observers::ClassMethods
    include DSL::Inputs
    extend DSL::Inputs::ClassMethods
    include DSL::NullListener
    include DSL::CallbackDefaults
    extend DSL::CallbackDefaults::ClassMethods
    include DSL::CallbackDefaults::InstanceMethods
    include DSL::ClassCallable
    extend DSL::ClassCallable::ClassMethods
    include DSL::Instrumented
    extend DSL::Instrumented::ClassMethods
    include DSL::Emits
    extend DSL::Emits::ClassMethods

    attr_reader listener: untyped
    attr_reader on_failure: Symbol
    attr_reader on_success: Symbol
    attr_reader failed: bool?
    attr_reader succeeded: bool?
    attr_reader result: Hash[Symbol, untyped]?

    def initialize: (?listener: untyped, ?on_failure: Symbol?, ?on_success: Symbol?, **untyped opts) -> void

    def failure?: () -> bool?
    def success?: () -> bool?

    private

    def failure: (*untyped failure_args, **untyped failure_opts) -> untyped
    def success: (*untyped success_args, **untyped success_opts) -> untyped
    def result_payload: (Hash[Symbol, untyped] opts, Array[untyped] args, key: Symbol) -> Hash[Symbol, untyped]
  end

  module QueryBuilder
    class PaginationError < Layers::Error
    end

    class ConfigurationError < Layers::Error
    end

    module Paginate
      def page: (untyped page) -> self
      def paginated: () -> bool?
      def per: (untyped size) -> self

      private

      def pagination_adapter: () -> untyped
    end

    module RelationDefaults
      def self.included: (Module base) -> void

      module ClassMethods
        def default_relation_class: () -> untyped
        def default_relation_class_name: () -> String?
        def relation_class: (untyped name_finder) -> String
      end

      def default_initial_relation: () -> untyped
    end

    module Sort
      def order: (?sort_field: Symbol, ?sort_direction: Symbol) -> self
    end
  end

  class BaseQueryObject
    class RelationError < Layers::Error
    end

    include QueryBuilder::RelationDefaults
    extend QueryBuilder::RelationDefaults::ClassMethods
    include QueryBuilder::Paginate
    include QueryBuilder::Sort

    attr_reader options: Hash[Symbol, untyped]
    attr_reader relation: untyped
    attr_reader unscoped_relation: untyped

    def initialize: (?untyped relation, **untyped options) -> void

    # delegated to relation
    def all: (?) -> untyped
    def count: (?) -> untyped
    def find: (?) -> untyped
    def find_by: (?) -> untyped
    def find_by!: (?) -> untyped
    def first: (?) -> untyped
    def includes: (?) -> untyped
    def joins: (?) -> untyped
    def last: (?) -> untyped
    def left_joins: (?) -> untyped
    def limit: (?) -> untyped
    def none: (?) -> untyped
    def offset: (?) -> untyped
    def pluck: (?) -> untyped
    def select: (?) -> untyped
    def where: (?) -> untyped

    private

    def validate_relation!: () -> void
    def build_relation_defaults!: () -> void
  end

  module BaseJob
    class InvalidUseCase < Layers::Error
    end

    class JobFailed < Layers::Error
    end

    def self.included: (Module base) -> void

    module ClassMethods
      def use_case: (String name_string) -> String
      def use_case_class_name: () -> String?
      def fire_and_forget: () -> bool
      def fire_and_forget?: () -> bool
    end

    def perform: (**untyped perform_args) -> untyped
    def success: (**untyped return_args) -> untyped
    def failure: (**untyped return_args) -> untyped
    def on_success: (**untyped args) -> void
    def on_failure: (**untyped args) -> untyped

    private

    def call_use_case: (**untyped args) -> untyped
    def job_listener: () -> untyped
    def use_case: () -> untyped
    def failed_message: (Hash[Symbol, untyped] args) -> String
    def failure_messages: (Hash[Symbol, untyped] args) -> Array[String]
    def extracted_errors: (untyped value) -> Array[String]
  end

  class BaseForm
    attr_writer persisted: bool

    def form_error_messages: () -> Array[String]
    def new_record?: () -> bool
    def persisted?: () -> bool

    private

    def report_full_errors_for: () -> Array[Symbol]
  end

  class BaseRegistry
    class NotRegistered < Layers::Error
    end

    class InvalidEntry < Layers::Error
    end

    def initialize: (**untyped entries) -> void

    def []: (Symbol | String name) -> untyped
    def register: (**untyped entries) -> untyped
    def remove: (Symbol | String name) -> String?
    def registered: () -> Array[Symbol]
    def registered?: (Symbol | String name) -> bool
    def to_h: () -> Hash[Symbol, String]

    private

    def store: () -> Hash[Symbol, String]
    def defaults: () -> Hash[untyped, untyped]
    def resolve: (Symbol key) -> untyped
  end

  class Doctor
    SLICE_DIRS: Array[String]

    class Problem
      attr_accessor slice: String
      attr_accessor message: String

      def initialize: (String slice, String message) -> void
    end

    def initialize: (?root: String) -> void

    def problems: () -> Array[Problem]
    def ok?: () -> bool

    private

    attr_reader root: String

    def slices: () -> Array[String]
    def slices_in: (String dir) -> Array[String]
    def check: (String slice) -> Array[Problem]
    def gemfile_problem: (String slice) -> Problem?
    def path_block_problem: (String slice) -> Problem?
    def spec_dir_problem: (String slice) -> Problem?
    def suite_runner_problems: () -> Array[Problem]
    def gemfile_declares?: (String family, String gem_name) -> boolish
    def root_gemfile: () -> String
  end

  module Skills
    class Installer
      class NoSkillCollections < Layers::Error
      end

      GEM_PREFIX: String

      def self.installed_specs: () -> Array[Gem::Specification]

      def initialize: (target_dir: String, ?specs: Array[Gem::Specification]) -> void

      def install: () -> Array[String]

      private

      attr_reader target_dir: String
      attr_reader specs: Array[Gem::Specification]

      def install_collection: (Gem::Specification spec) -> String
      def copy_entries: (String source, String destination) -> void
    end

    class Cloner
      class GitCommandFailed < Layers::Error
      end

      COLLECTIONS: Array[String]
      DEFAULT_BASE_URL: String

      def initialize: (target_dir: String, ?base_url: String, ?runner: ^(*String) -> boolish) -> void

      def clone: () -> Hash[String, Symbol]

      private

      attr_reader target_dir: String
      attr_reader base_url: String
      attr_reader runner: ^(*String) -> boolish

      def clone_or_pull: (String collection) -> Symbol
      def pull: (String destination, String collection) -> Symbol
      def repo_url: (String collection) -> String
      def run: (*String command, collection: String) -> void
    end
  end

  module Graphql
    module BaseEndpoint
      class InvalidUserStory < Layers::Error
      end

      class InvalidUserStoryArgumentMethod < Layers::Error
        def initialize: (Symbol? method_name) -> void
      end

      WIRING_ERRORS: Array[Class]

      def self.included: (Module base) -> void

      module ClassMethods
        def user_story: (String name_string) -> String
        def user_story_class_name: () -> String?
        def user_story_arg: (Symbol arg, ?Hash[Symbol, untyped] opts) -> Hash[Symbol, untyped]
        def user_story_args: () -> Hash[Symbol, Hash[Symbol, untyped]]
      end

      attr_reader initial_resolve_args: Hash[Symbol, untyped]

      def resolve: (**untyped resolve_args) -> untyped
      def success: (**untyped return_args) -> untyped
      def failure: (**untyped return_args) -> untyped
      def on_success: (**untyped args) -> untyped
      def on_failure: (**untyped args) -> untyped

      private

      def client_facing_message: (Exception error) -> String
      def context_has_errors?: () -> untyped
      def execute!: () -> untyped
      def execution_args: () -> Hash[Symbol, untyped]
      def execution_error_class: () -> untyped
      def expose_error?: (Exception error) -> bool
      def log_masked_error: (Exception error) -> void
      def logger: () -> untyped
      def wiring_error?: (Exception error) -> bool
      def user_story: () -> untyped
      def user_story_args: () -> Hash[Symbol, untyped]
    end
  end

  module Adapters
    module Pagination
      class Kaminari
        def self.page: (untyped relation, untyped number) -> untyped
        def self.per: (untyped relation, untyped size) -> untyped
      end

      class WillPaginate
        def self.page: (untyped relation, untyped number) -> untyped
        def self.per: (untyped relation, untyped size) -> untyped
      end
    end

    module Relation
      class ActiveRecord
        def self.relation?: (untyped object) -> bool
      end

      class DuckType
        def self.relation?: (untyped object) -> bool
      end
    end
  end
end
